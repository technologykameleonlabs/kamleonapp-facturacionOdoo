# === Supabase REST / SDK ===
# URL única de tu proyecto Supabase.
# La encuentras en: Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Clave privilegiada (service_role).
# La encuentras en: Project Settings → API → Project API Keys → service_role
# ⚠️ Solo usar en scripts backend o locales (nunca en frontend público).
SUPABASE_SERVICE_ROLE=YOUR_SERVICE_ROLE_KEY

# (Opcional) Clave pública (anon).
# La encuentras en: Project Settings → API → Project API Keys → anon
# Úsala si quieres hacer queries de solo lectura desde SDK de forma segura.
# Si no la necesitas, puedes dejarla comentada.
# SUPABASE_ANON_KEY=YOUR_ANON_KEY


# === Conexión directa a PostgreSQL (para ejecutar .sql) ===
# Ve a: Settings → Database → Connection info
# Rellena aquí los campos independientes:
PGHOST=db.YOUR_PROJECT.supabase.co   # Host
PGPORT=5432                          # Puerto (usa siempre 5432, no el pooler 6543)
PGDATABASE=postgres                  # Nombre de la base de datos (por defecto "postgres")
PGUSER=postgres                      # Usuario (por defecto "postgres")
PGPASSWORD=YOUR_DB_PASSWORD          # Tu password de la base de datos
PGSSLMODE=require                    # Recomendado para conexiones externas