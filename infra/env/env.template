# =====================================================
# KAMELEON APP - CONFIGURACIÓN DE BASE DE DATOS
# =====================================================
# Copia este archivo como .env.local y configura tus valores

# =====================================================
# CONFIGURACIÓN DE SUPABASE
# =====================================================
# URL de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima de Supabase (para operaciones públicas)
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Clave de servicio de Supabase (para operaciones administrativas)
# IMPORTANTE: Mantén esta clave segura, no la expongas en el frontend
SUPABASE_SERVICE_ROLE=tu_service_role_key_aqui

# =====================================================
# CONFIGURACIÓN DE POSTGRESQL (OPCIONAL)
# =====================================================
# Si prefieres conectar directamente a PostgreSQL en lugar de usar Supabase
# Descomenta y configura estas variables:

# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=kameleon_app
# PGUSER=postgres
# PGPASSWORD=tu_password
# PGSSLMODE=prefer

# =====================================================
# CONFIGURACIÓN DE DESARROLLO
# =====================================================
# Entorno de desarrollo
NODE_ENV=development

# =====================================================
# INSTRUCCIONES DE CONFIGURACIÓN
# =====================================================
# 1. Copia este archivo: cp infra/env/env.template infra/env/.env.local
# 2. Configura las variables de Supabase:
#    - Ve a tu proyecto en https://supabase.com/dashboard
#    - Ve a Settings > API
#    - Copia la URL y las claves correspondientes
# 3. Si usas PostgreSQL directo, configura las variables PGHOST, etc.
# 4. Ejecuta: npm run db:setup

# =====================================================
# VERIFICACIÓN
# =====================================================
# Para verificar que la configuración es correcta:
# npm run db:verify

# =====================================================
# COMANDOS DISPONIBLES
# =====================================================
# npm run db:setup          # Instalar base de datos completa
# npm run db:setup -- --mode=ddl    # Solo estructura
# npm run db:setup -- --mode=mock   # Solo datos mock
# npm run db:verify          # Verificar instalación
# npm run db:cleanup         # Limpiar base de datos
# npm run db:query           # Ejecutar consulta de ejemplo
